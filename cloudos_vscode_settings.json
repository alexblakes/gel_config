// These VSCode workspace settings belong in <project_root>/.vscode/settings.json
{
    "workbench.sideBar.location": "right",
    "git.enabled": true,
    "git.confirmSync": false,
    "jupyter.askForKernelRestart": false,
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[snakemake]": {
        "editor.defaultFormatter": "tfehlmann.snakefmt"
    },
    "python-envs.defaultEnvManager": "renan-r-santos.pixi-code:pixi",
    "python-envs.defaultPackageManager": "renan-r-santos.pixi-code:pixi"
}